{
  "name": "opencode-starter",
  "version": "0.3.0",
  "description": "Launch Claude Code with OpenCode Zen, Go, or local providers — with mid-session model switching via favorites",
  "author": "jacob-bd",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jacob-bd/opencode-starter.git"
  },
  "homepage": "https://github.com/jacob-bd/opencode-starter#readme",
  "keywords": [
    "claude",
    "claude-code",
    "opencode",
    "ai",
    "llm",
    "cli"
  ],
  "type": "module",
  "bin": {
    "opencode-starter": "dist/cli.js"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "@napi-rs/keyring": "^1.3.0"
  }
}
